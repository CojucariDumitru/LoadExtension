{
  "manifest_version": 3,
  "name": "LoadExtension",
  "version": "0.2.0",
  "description": "Self-hosted dispatch helper for load boards — RPM filters, one-click email, maps, and Telegram alerts.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://one.dat.com/*",
    "https://power.dat.com/*",
    "https://*.truckstop.com/*",
    "https://*.trucksmarter.com/*",
    "https://api.telegram.org/*",
    "https://mobile.fmcsa.dot.gov/*",
    "https://apis.tollguru.com/*",
    "https://rtspro.com/*",
    "http://webservice.rtscredit.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LoadExtension",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://one.dat.com/*",
        "https://power.dat.com/*",
        "https://*.truckstop.com/*",
        "https://*.trucksmarter.com/*"
      ],
      "js": ["dist/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://rtspro.com/*"],
      "js": ["content/rts-capture.js"],
      "run_at": "document_idle"
    }
  ]
}
